# API Keys (required)
# Get your Groq API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Get your Nomic API key at: https://atlas.nomic.ai/
NOMIC_API_KEY=your_nomic_api_key_here

# Model settings (optional - defaults shown)
# GROQ_MODEL=llama-3.1-8b-instant
# EMBEDDING_MODEL=nomic-embed-text-v1.5
# TEMPERATURE=0.7
# MAX_TOKENS=4096

# Text splitting (optional)
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200

# Retrieval (optional)
# RETRIEVAL_K=4
